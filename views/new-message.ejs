<html>
    <head>
        <title><%= title %></title>
    </head>
    <body>
        <%- include('./partials/formErrors.ejs') %>
        <form action="/message/<%= id %>" method="POST">
            <h1>New Message</h1>
            <label for="title">Title: </label>
            <input type="text" name="title" id="title">
            <label for="text">Message: </label>
            <textarea name="text" id="text" cols="30" rows="10">Type your message here...</textarea>
            <button type="submit">Submit</button>
        </form>
    </body>
</html>